---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";
import Section from "@components/shared/Section.astro";
import Card from "@components/shared/Card.astro";
import Badge from "@components/shared/Badge.astro";
import { tools } from "@data/tools";
import { site } from "@data/site";
import { breadcrumbJsonLd } from "@lib/structured-data";

const categories = [...new Set(tools.map((tool) => tool.category))];
const structuredData = breadcrumbJsonLd([
  { name: "Beranda", url: site.url },
  { name: "Tools", url: new URL("/tools", site.url).toString() }
]);
---

<BaseLayout
  title="Tools server dan domain"
  description="Katalog tools DNS, domain age, RDAP, SSL, HTTP header, email auth, dan IP lookup untuk kebutuhan audit teknis."
  canonical="/tools"
  structuredData={structuredData}
>
  <PageHeader
    eyebrow="Tools"
    title="Tools kecil buat ngecek domain, DNS, SSL, dan server."
    description="Kumpulan checker yang jalan lewat Astro endpoint dan runtime Node. Mulai dari lookup DNS sampai domain age, tanpa harus buka terminal dulu."
  />

  <Section>
    <div class="mb-7 flex flex-wrap gap-2">
      {categories.map((category) => <Badge tone="neutral">{category}</Badge>)}
    </div>
    <div class="grid gap-[22px] md:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <Card href={`/tools/${tool.slug}`}>
            <div class="grid h-full gap-4 p-5">
              <div class="flex flex-wrap items-center gap-2">
                <Badge tone="accent">{tool.category}</Badge>
                <span class="rounded-full bg-surface-muted px-2.5 py-1 text-[0.78rem] font-black text-text-secondary [border:1.5px_solid_var(--color-border)]">
                  Live checker
                </span>
              </div>
              <div class="grid gap-2">
                <h2 class="m-0 text-[1.3rem] font-black leading-tight">{tool.title}</h2>
                <p class="m-0 leading-[1.65] text-text-secondary">{tool.summary}</p>
              </div>
              <ul class="m-0 grid gap-1.5 p-0">
                {tool.checks.slice(0, 3).map((check) => <li class="list-none text-[0.9rem] font-bold text-text-primary">- {check}</li>)}
              </ul>
            </div>
          </Card>
        ))
      }
    </div>
  </Section>
</BaseLayout>
