---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/shared/PageHeader.astro";
import Section from "@components/shared/Section.astro";
import Button from "@components/shared/Button.astro";
import Badge from "@components/shared/Badge.astro";
import LinkQrCodeTool from "@components/tools/LinkQrCodeTool.astro";
import { tools } from "@data/tools";
import { site } from "@data/site";
import { breadcrumbJsonLd } from "@lib/structured-data";

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { tool: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const isQrTool = tool.slug === "link-to-qr-code";
const toolUrl = new URL(`/tools/${tool.slug}`, site.url).toString();
const relatedTools = tools
  .filter((item) => item.slug !== tool.slug && item.category === tool.category)
  .slice(0, 3);
const recordOptions = ["A", "AAAA", "NS", "MX", "TXT", "CAA", "SOA"];
const formConfigBySlug: Record<string, { label: string; placeholder: string; helper: string }> = {
  "link-to-qr-code": {
    label: "URL",
    placeholder: "https://wildanisme.com",
    helper: "Masukkan link, lalu generate QR code langsung di browser. Tidak ada request ke server untuk isi QR."
  },
  "dns-lookup": {
    label: "Domain atau subdomain",
    placeholder: "wildanisme.com",
    helper: "Masukkan domain tanpa http:// agar record DNS-nya dicek satu per satu."
  },
  "dns-propagation": {
    label: "Domain",
    placeholder: "wildanisme.com",
    helper: "Pilih record, lalu bandingkan hasilnya dari beberapa resolver publik."
  },
  "domain-age": {
    label: "Domain root",
    placeholder: "wildanisme.com",
    helper: "RDAP biasanya paling rapi untuk melihat event registrasi domain."
  },
  "rdap-whois": {
    label: "Domain atau IP publik",
    placeholder: "wildanisme.com atau 1.1.1.1",
    helper: "Lookup ini otomatis memakai RDAP domain atau RDAP IP sesuai target."
  },
  "ssl-expiry": {
    label: "Hostname",
    placeholder: "wildanisme.com",
    helper: "Gunakan hostname publik. Target localhost dan IP private sengaja diblokir."
  },
  "http-header-check": {
    label: "URL atau hostname",
    placeholder: "https://wildanisme.com",
    helper: "Cek status, redirect, cache, dan security header dari server."
  },
  "email-auth-check": {
    label: "Domain email",
    placeholder: "wildanisme.com",
    helper: "SPF dan DMARC bisa dicek langsung. DKIM butuh selector, default-nya default."
  },
  "reverse-dns": {
    label: "IP address",
    placeholder: "1.1.1.1",
    helper: "Masukkan IPv4 atau IPv6 untuk mencari PTR/reverse DNS."
  },
  "ip-asn-lookup": {
    label: "IP address",
    placeholder: "1.1.1.1",
    helper: "Masukkan IP publik untuk melihat data RDAP jaringan dan pemilik ASN."
  }
};
const formConfig = formConfigBySlug[tool.slug] ?? {
  label: "Input",
  placeholder: "wildanisme.com",
  helper: "Masukkan target yang ingin dicek."
};
const structuredData = breadcrumbJsonLd([
  { name: "Beranda", url: site.url },
  { name: "Tools", url: new URL("/tools", site.url).toString() },
  { name: tool.title, url: toolUrl }
]);
---

<BaseLayout
  title={tool.title}
  description={tool.summary}
  canonical={`/tools/${tool.slug}`}
  image={isQrTool ? "/images/og/link-to-qr-code.png" : undefined}
  structuredData={structuredData}
>
  <PageHeader eyebrow={tool.category} title={tool.title} description={tool.description}>
    <div class="flex flex-wrap gap-3">
      <Button href="/tools" variant="secondary">Lihat semua tools</Button>
    </div>
  </PageHeader>

  <Section>
    <div class="grid min-w-0 gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
      <article class="grid w-full min-w-0 gap-6">
        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-accent-soft p-5 shadow-brutal [border:var(--border-strong)]">
          <div class="mb-4 grid gap-2">
            <h2 class="m-0 text-[1.45rem] font-black">Coba langsung</h2>
            <p class="m-0 max-w-[68ch] leading-[1.65] text-text-secondary">{formConfig.helper}</p>
          </div>

          {
            isQrTool ? (
              <LinkQrCodeTool />
            ) : (
              <>
                <form class="grid gap-4" data-tool-form data-tool-slug={tool.slug}>
                  <div class="grid gap-2">
                    <label class="text-[0.92rem] font-black" for="tool-target">{formConfig.label}</label>
                    <input
                      id="tool-target"
                      class="min-h-12 w-full min-w-0 rounded-card bg-background px-4 py-3 font-bold text-text-primary outline-none [border:2px_solid_var(--color-border)] placeholder:text-text-muted focus:[box-shadow:0_0_0_3px_var(--color-accent-soft)]"
                      name="target"
                      placeholder={formConfig.placeholder}
                      required
                      type="text"
                    />
                  </div>

                  {
                    tool.slug === "dns-propagation" && (
                      <div class="grid gap-2">
                        <label class="text-[0.92rem] font-black" for="tool-record">Record</label>
                        <select
                          id="tool-record"
                          class="min-h-12 w-full rounded-card bg-background px-4 py-3 font-bold text-text-primary outline-none [border:2px_solid_var(--color-border)] focus:[box-shadow:0_0_0_3px_var(--color-accent-soft)]"
                          name="record"
                        >
                          {recordOptions.map((record) => (
                            <option value={record}>{record}</option>
                          ))}
                        </select>
                      </div>
                    )
                  }

                  {
                    tool.slug === "email-auth-check" && (
                      <div class="grid gap-2">
                        <label class="text-[0.92rem] font-black" for="tool-selector">Selector DKIM</label>
                        <input
                          id="tool-selector"
                          class="min-h-12 w-full min-w-0 rounded-card bg-background px-4 py-3 font-bold text-text-primary outline-none [border:2px_solid_var(--color-border)] placeholder:text-text-muted focus:[box-shadow:0_0_0_3px_var(--color-accent-soft)]"
                          name="selector"
                          placeholder="default"
                          type="text"
                        />
                      </div>
                    )
                  }

                  {
                    tool.slug === "ssl-expiry" && (
                      <div class="grid gap-2">
                        <label class="text-[0.92rem] font-black" for="tool-port">Port</label>
                        <input
                          id="tool-port"
                          class="min-h-12 w-full min-w-0 rounded-card bg-background px-4 py-3 font-bold text-text-primary outline-none [border:2px_solid_var(--color-border)] placeholder:text-text-muted focus:[box-shadow:0_0_0_3px_var(--color-accent-soft)]"
                          inputmode="numeric"
                          max="65535"
                          min="1"
                          name="port"
                          placeholder="443"
                          type="number"
                        />
                      </div>
                    )
                  }

                  <div class="flex flex-wrap items-center gap-3">
                    <button
                      class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-card bg-primary px-5 py-2.5 text-[0.95rem] font-black text-gray-800 shadow-brutal-sm transition hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60 [border:var(--border-strong)]"
                      data-tool-submit
                      type="submit"
                    >
                      Jalankan cek
                    </button>
                    <p class="m-0 text-[0.92rem] font-bold text-text-secondary" data-tool-status role="status">
                      Siap ngecek. Masukkan target dulu.
                    </p>
                  </div>
                </form>

                <div class="mt-5 hidden rounded-card bg-surface p-4 shadow-brutal-sm [border:var(--border-strong)]" data-tool-result>
                  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <h3 class="m-0 text-[1.15rem] font-black">Output</h3>
                      <p class="m-0 text-[0.9rem] font-bold text-text-secondary" data-tool-summary>
                        Hasil cek akan muncul di sini.
                      </p>
                    </div>
                    <div class="flex flex-wrap gap-2" aria-label="Mode output">
                      <button
                        class="cursor-pointer rounded-full bg-accent px-3 py-1.5 text-[0.8rem] font-black text-text-primary transition hover:translate-x-px hover:translate-y-px [border:var(--border-strong)]"
                        type="button"
                        data-output-mode="readable"
                        aria-pressed="true"
                      >
                        Ringkasan
                      </button>
                      <button
                        class="cursor-pointer rounded-full bg-surface-muted px-3 py-1.5 text-[0.8rem] font-black text-text-secondary transition hover:bg-accent-soft hover:text-text-primary [border:1.5px_solid_var(--color-border)]"
                        type="button"
                        data-output-mode="json"
                        aria-pressed="false"
                      >
                        Raw JSON
                      </button>
                      <button
                        class="cursor-pointer rounded-full bg-surface-muted px-3 py-1.5 text-[0.8rem] font-black text-text-secondary transition hover:bg-accent-soft hover:text-text-primary [border:1.5px_solid_var(--color-border)]"
                        type="button"
                        data-tool-copy-json
                      >
                        Copy JSON
                      </button>
                    </div>
                  </div>
                  <div class="grid gap-4" data-tool-readable></div>
                  <pre class="m-0 hidden max-h-[520px] max-w-full overflow-auto whitespace-pre-wrap break-words rounded-card bg-[#151a18] p-4 text-[0.82rem] leading-[1.65] text-white"><code data-tool-output></code></pre>
                </div>
              </>
            )
          }
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-4 text-[1.45rem] font-black">Fungsi utama</h2>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <h3 class="m-0 mb-2 text-[1rem] font-black">Cocok untuk</h3>
              <ul class="m-0 grid gap-2 p-0">
                {tool.bestFor.map((item) => <li class="list-none leading-[1.6] text-text-secondary">- {item}</li>)}
              </ul>
            </div>
            <div>
              <h3 class="m-0 mb-2 text-[1rem] font-black">Input</h3>
              <ul class="m-0 grid gap-2 p-0">
                {tool.inputs.map((item) => <li class="list-none leading-[1.6] text-text-secondary">- {item}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-4 text-[1.45rem] font-black">Yang dicek</h2>
          <div class="flex flex-wrap gap-2">
            {tool.checks.map((check) => <Badge tone="neutral">{check}</Badge>)}
          </div>
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-4 text-[1.45rem] font-black">Output yang ideal</h2>
          <ul class="m-0 grid gap-2 p-0">
            {tool.output.map((item) => <li class="list-none leading-[1.6] text-text-secondary">- {item}</li>)}
          </ul>
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-code-surface p-5 text-white shadow-brutal [border:var(--border-strong)]">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <h2 class="m-0 text-[1.45rem] font-black">Contoh implementasi Node</h2>
            <span class="rounded-full bg-accent px-2.5 py-1 text-[0.78rem] font-black text-text-primary [border:var(--border-strong)]">
              Astro endpoint ready
            </span>
          </div>
          <pre class="m-0 max-w-full overflow-x-auto rounded-card bg-[#151a18] p-4 text-[0.88rem] leading-[1.7]"><code>{tool.exampleCode}</code></pre>
        </section>
      </article>

      <aside class="grid w-full min-w-0 content-start gap-6">
        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-accent-soft p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-3 text-[1.1rem] font-black">Runtime Astro</h2>
          <p class="m-0 leading-[1.65] text-text-secondary">{tool.astroNote}</p>
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-3 text-[1.1rem] font-black">API Node yang dipakai</h2>
          <ul class="m-0 grid gap-2 p-0">
            {tool.nodeRuntime.map((item) => <li class="list-none break-words font-bold text-text-secondary">- {item}</li>)}
          </ul>
        </section>

        <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
          <h2 class="m-0 mb-3 text-[1.1rem] font-black">Batasan</h2>
          <ul class="m-0 grid gap-2 p-0">
            {tool.limitations.map((item) => <li class="list-none leading-[1.6] text-text-secondary">- {item}</li>)}
          </ul>
        </section>

        {
          relatedTools.length > 0 && (
            <section class="w-full min-w-0 max-w-full overflow-hidden rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
              <h2 class="m-0 mb-3 text-[1.1rem] font-black">Tools terkait</h2>
              <div class="grid gap-2">
                {relatedTools.map((item) => (
                  <a class="font-black underline decoration-2 underline-offset-4 hover:text-accent-secondary" href={`/tools/${item.slug}`}>
                    {item.title}
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </aside>
    </div>
  </Section>

  <script>
    type ToolPayload = {
      tool: string;
      checkedAt: string;
      durationMs: number;
      result: any;
    };

    const toolLabels: Record<string, string> = {
      "dns-lookup": "DNS Lookup",
      "dns-propagation": "DNS Propagation",
      "domain-age": "Domain Age",
      "rdap-whois": "RDAP WHOIS",
      "ssl-expiry": "SSL Expiry",
      "http-header-check": "HTTP Header",
      "email-auth-check": "Email Auth",
      "reverse-dns": "Reverse DNS",
      "ip-asn-lookup": "IP ASN"
    };

    const recordLabels: Record<string, string> = {
      a: "A Record",
      aaaa: "AAAA Record",
      ns: "NS Record",
      mx: "MX Record",
      txt: "TXT Record",
      caa: "CAA Record",
      soa: "SOA Record"
    };

    const recordHints: Record<string, string> = {
      a: "IPv4 address",
      aaaa: "IPv6 address",
      ns: "Nameserver",
      mx: "Mail server",
      txt: "Text record",
      caa: "Certificate authority",
      soa: "Zone authority"
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const toTitle = (value: string) =>
      value
        .replaceAll("-", " ")
        .replaceAll("_", " ")
        .replace(/\b\w/g, (letter) => letter.toUpperCase());

    const formatDateTime = (value?: string) => {
      if (!value) return "-";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat("id-ID", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const flattenTxt = (value: unknown) =>
      Array.isArray(value)
        ? value.map((row) => (Array.isArray(row) ? row.join("") : String(row)))
        : [];

    const asList = (value: unknown) => {
      if (value === null || value === undefined || value === "") return [];
      return Array.isArray(value) ? value : [value];
    };

    const formatValue = (value: unknown): string => {
      if (value === null || value === undefined || value === "") return "-";
      if (typeof value === "string" || typeof value === "number" || typeof value === "boolean") {
        return escapeHtml(value);
      }
      if (Array.isArray(value)) {
        return value.map((item) => formatValue(item)).join(", ");
      }
      if (typeof value === "object") {
        return Object.entries(value)
          .map(([key, item]) => `${escapeHtml(toTitle(key))}: ${formatValue(item)}`)
          .join("<br />");
      }
      return escapeHtml(String(value));
    };

    const badge = (label: string, tone: "ok" | "warn" | "neutral" = "neutral") => {
      const className =
        tone === "ok"
          ? "bg-accent text-text-primary [border:var(--border-strong)]"
          : tone === "warn"
            ? "bg-[#fff1d6] text-text-primary [border:var(--border-strong)]"
            : "bg-surface-muted text-text-secondary [border:1.5px_solid_var(--color-border)]";
      return `<span class="inline-flex w-fit rounded-full px-2.5 py-1 text-[0.78rem] font-black ${className}">${escapeHtml(label)}</span>`;
    };

    const shell = (title: string, description: string, body: string, tone: "default" | "muted" | "warning" = "default") => {
      const toneClass =
        tone === "warning"
          ? "bg-[#fff7e8]"
          : tone === "muted"
            ? "bg-surface-muted"
            : "bg-background";
      return `
        <section class="rounded-card ${toneClass} p-4 [border:var(--border-strong)]">
          <div class="mb-3 flex flex-wrap items-start justify-between gap-3">
            <div>
              <h4 class="m-0 text-[1rem] font-black">${escapeHtml(title)}</h4>
              <p class="m-0 mt-1 text-[0.88rem] font-bold text-text-secondary">${escapeHtml(description)}</p>
            </div>
          </div>
          ${body}
        </section>
      `;
    };

    const valueList = (values: unknown[], empty = "Tidak ada data.") => {
      if (values.length === 0) {
        return `<p class="m-0 rounded-card bg-surface p-3 font-bold text-text-secondary [border:1.5px_solid_var(--color-border)]">${escapeHtml(empty)}</p>`;
      }

      return `<div class="grid gap-2">${values
        .map(
          (value) =>
            `<div class="break-words rounded-card bg-surface p-3 font-mono text-[0.88rem] font-bold leading-[1.6] [border:1.5px_solid_var(--color-border)]">${formatValue(value)}</div>`
        )
        .join("")}</div>`;
    };

    const keyValueGrid = (items: Array<[string, unknown]>) => `
      <dl class="grid gap-2 md:grid-cols-2">
        ${items
          .map(
            ([key, value]) => `
              <div class="rounded-card bg-surface p-3 [border:1.5px_solid_var(--color-border)]">
                <dt class="mb-1 text-[0.78rem] font-black uppercase text-text-secondary">${escapeHtml(key)}</dt>
                <dd class="m-0 break-words font-black leading-[1.5]">${formatValue(value)}</dd>
              </div>
            `
          )
          .join("")}
      </dl>
    `;

    const fallbackNotice = (external: any) =>
      external?.fallback
        ? shell(
            "Fallback aktif",
            external.message ?? "Sumber eksternal belum memberi data.",
            keyValueGrid([
              ["Target", external.target],
              ["Error", external.error],
              ["Source dicoba", asList(external.triedSources).join(", ")]
            ]),
            "warning"
          )
        : "";

    const renderRecordCard = (title: string, hint: string, lookup: any) => {
      const values = lookup?.ok ? lookup.data : [];
      const normalized = title === "TXT Record" ? flattenTxt(values) : asList(values);
      return shell(
        title,
        hint,
        `${lookup?.ok ? badge("OK", "ok") : badge("Tidak ditemukan", "warn")}
        <div class="mt-3">${valueList(normalized, lookup?.error ?? "Record ini tidak ditemukan.")}</div>`
      );
    };

    const renderDnsLookup = (payload: ToolPayload) => {
      const result = payload.result;
      const records = result.records ?? {};
      const order = ["a", "aaaa", "mx", "txt", "ns", "caa", "soa"];
      return `
        ${shell(
          `DNS Records untuk ${result.domain}`,
          `Dicek ${formatDateTime(payload.checkedAt)} dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Domain", result.domain],
            ["Total record group", order.length]
          ]),
          "muted"
        )}
        <div class="grid gap-4">
          ${order.map((key) => renderRecordCard(recordLabels[key], recordHints[key], records[key])).join("")}
        </div>
      `;
    };

    const renderDnsPropagation = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${shell(
          `Propagasi ${result.record} untuk ${result.domain}`,
          `Dicek dari ${asList(result.resolvers).length} resolver publik dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Domain", result.domain],
            ["Record", result.record]
          ]),
          "muted"
        )}
        <div class="grid gap-4 md:grid-cols-2">
          ${asList(result.resolvers)
            .map((resolver: any) =>
              shell(
                resolver.name,
                resolver.server,
                `${resolver.result?.ok ? badge("OK", "ok") : badge("Gagal", "warn")}
                <div class="mt-3">${valueList(asList(resolver.result?.data), resolver.result?.error ?? "Tidak ada hasil.")}</div>`
              )
            )
            .join("")}
        </div>
      `;
    };

    const renderDomainAge = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${fallbackNotice(result.external)}
        ${shell(
          `Umur domain ${result.domain}`,
          result.source ? `Source: ${result.source}` : `Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Registrar", result.registrar],
            ["Tanggal daftar", result.age?.createdAt ? formatDateTime(result.age.createdAt) : "-"],
            ["Umur", result.age ? `${result.age.days} hari (${result.age.years} tahun)` : "-"],
            ["Status", asList(result.status).join(", ") || "-"]
          ]),
          "muted"
        )}
        ${shell("Events", "Tanggal penting dari data RDAP", valueList(asList(result.events)))}
      `;
    };

    const renderRdapWhois = (payload: ToolPayload) => {
      const result = payload.result;
      const isIp = result.type === "ip";
      return `
        ${fallbackNotice(result.external)}
        ${shell(
          isIp ? `RDAP IP ${result.ip}` : `RDAP domain ${result.domain}`,
          result.source ? `Source: ${result.source}` : `Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid(
            isIp
              ? [
                  ["Handle", result.handle],
                  ["Name", result.name],
                  ["Type", result.networkType],
                  ["Country", result.country],
                  ["Range", result.startAddress && result.endAddress ? `${result.startAddress} - ${result.endAddress}` : "-"]
                ]
              : [
                  ["Handle", result.handle],
                  ["Registrar", result.registrar],
                  ["Nameserver", asList(result.nameservers).join(", ") || "-"],
                  ["Status", asList(result.status).join(", ") || "-"]
                ]
          ),
          "muted"
        )}
        ${shell("Entities", "Kontak atau organisasi dari data RDAP", valueList(asList(result.entities)))}
        ${shell("Events", "Tanggal penting dari registry", valueList(asList(result.events)))}
      `;
    };

    const renderSslExpiry = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${fallbackNotice(result.external)}
        ${shell(
          `SSL ${result.hostname}:${result.port}`,
          `Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Issuer", result.issuer?.CN ?? result.issuer?.O ?? "-"],
            ["Subject", result.subject?.CN ?? "-"],
            ["Valid from", result.validFrom],
            ["Valid to", result.validTo],
            ["Sisa hari", result.daysRemaining === null || result.daysRemaining === undefined ? "-" : `${result.daysRemaining} hari`],
            ["SAN", result.subjectAltName]
          ]),
          "muted"
        )}
      `;
    };

    const renderHttpHeaders = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${fallbackNotice(result.external)}
        ${shell(
          "HTTP Header",
          `Redirect count: ${result.redirectCount ?? 0}. Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Input", result.input],
            ["Final URL", result.finalUrl ?? "-"]
          ]),
          "muted"
        )}
        <div class="grid gap-4">
          ${asList(result.chain)
            .map((item: any) =>
              shell(
                `${item.status} ${item.url}`,
                "Response header penting",
                keyValueGrid([
                  ["Location", item.headers?.location],
                  ["Cache-Control", item.headers?.cacheControl],
                  ["Content-Type", item.headers?.contentType],
                  ["Server", item.headers?.server],
                  ["HSTS", item.headers?.strictTransportSecurity],
                  ["CSP", item.headers?.contentSecurityPolicy],
                  ["X-Frame-Options", item.headers?.xFrameOptions],
                  ["X-Content-Type-Options", item.headers?.xContentTypeOptions]
                ])
              )
            )
            .join("") || shell("Tidak ada response", "Target belum memberi header.", "")}
        </div>
      `;
    };

    const renderEmailAuth = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${shell(
          `Email auth untuk ${result.domain}`,
          `Selector DKIM: ${result.selector}. Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["SPF ditemukan", result.spf?.length ?? 0],
            ["DMARC ditemukan", result.dmarc?.length ?? 0],
            ["DKIM ditemukan", result.dkim?.length ?? 0]
          ]),
          "muted"
        )}
        ${shell("SPF", "Sender Policy Framework", valueList(asList(result.spf), "SPF belum ditemukan."))}
        ${shell("DMARC", "Policy email domain", valueList(asList(result.dmarc), "DMARC belum ditemukan."))}
        ${shell("DKIM", "Selector yang dicek", valueList(asList(result.dkim), "DKIM tidak ditemukan untuk selector ini."))}
      `;
    };

    const renderReverseDns = (payload: ToolPayload) => {
      const result = payload.result;
      return shell(
        `Reverse DNS ${result.ip}`,
        `Dicek dalam ${payload.durationMs} ms`,
        `${result.hostnames?.ok ? badge("OK", "ok") : badge("Tidak ditemukan", "warn")}
        <div class="mt-3">${valueList(asList(result.hostnames?.data), result.hostnames?.error ?? "PTR tidak ditemukan.")}</div>`,
        "muted"
      );
    };

    const renderIpAsn = (payload: ToolPayload) => {
      const result = payload.result;
      return `
        ${fallbackNotice(result.external)}
        ${shell(
          `IP ASN ${result.ip}`,
          result.source ? `Source: ${result.source}` : `Dicek dalam ${payload.durationMs} ms`,
          keyValueGrid([
            ["Handle", result.handle],
            ["Name", result.name],
            ["Type", result.type],
            ["Country", result.country],
            ["Range", result.startAddress && result.endAddress ? `${result.startAddress} - ${result.endAddress}` : "-"]
          ]),
          "muted"
        )}
        ${shell("Entities", "Organisasi terkait IP", valueList(asList(result.entities)))}
      `;
    };

    const renderReadableOutput = (payload: ToolPayload) => {
      switch (payload.tool) {
        case "dns-lookup":
          return renderDnsLookup(payload);
        case "dns-propagation":
          return renderDnsPropagation(payload);
        case "domain-age":
          return renderDomainAge(payload);
        case "rdap-whois":
          return renderRdapWhois(payload);
        case "ssl-expiry":
          return renderSslExpiry(payload);
        case "http-header-check":
          return renderHttpHeaders(payload);
        case "email-auth-check":
          return renderEmailAuth(payload);
        case "reverse-dns":
          return renderReverseDns(payload);
        case "ip-asn-lookup":
          return renderIpAsn(payload);
        default:
          return shell(toolLabels[payload.tool] ?? "Output", `Dicek dalam ${payload.durationMs} ms`, valueList([payload.result]));
      }
    };

    function setOutputMode(resultPanel: HTMLElement, mode: "readable" | "json") {
      const readable = resultPanel.querySelector<HTMLElement>("[data-tool-readable]");
      const raw = resultPanel.querySelector<HTMLElement>("[data-tool-output]")?.closest("pre");
      const buttons = resultPanel.querySelectorAll<HTMLButtonElement>("[data-output-mode]");

      readable?.classList.toggle("hidden", mode !== "readable");
      raw?.classList.toggle("hidden", mode !== "json");
      buttons.forEach((button) => {
        const isActive = button.dataset.outputMode === mode;
        button.setAttribute("aria-pressed", String(isActive));
        button.className = isActive
          ? "cursor-pointer rounded-full bg-accent px-3 py-1.5 text-[0.8rem] font-black text-text-primary transition hover:translate-x-px hover:translate-y-px [border:var(--border-strong)]"
          : "cursor-pointer rounded-full bg-surface-muted px-3 py-1.5 text-[0.8rem] font-black text-text-secondary transition hover:bg-accent-soft hover:text-text-primary [border:1.5px_solid_var(--color-border)]";
      });
    }

    function initializeToolForm() {
      const form = document.querySelector<HTMLFormElement>("[data-tool-form]");
      if (!form || form.dataset.toolFormReady === "true") return;

      const resultPanel = document.querySelector<HTMLElement>("[data-tool-result]");
      const readableOutput = document.querySelector<HTMLElement>("[data-tool-readable]");
      const output = document.querySelector<HTMLElement>("[data-tool-output]");
      const summary = document.querySelector<HTMLElement>("[data-tool-summary]");
      const statusText = document.querySelector<HTMLElement>("[data-tool-status]");
      const submitButton = document.querySelector<HTMLButtonElement>("[data-tool-submit]");
      const copyJsonButton = document.querySelector<HTMLButtonElement>("[data-tool-copy-json]");
      let latestJson = "";

      form.dataset.toolFormReady = "true";
      resultPanel?.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-output-mode]");
        if (!button || !resultPanel.contains(button)) return;
        setOutputMode(resultPanel, button.dataset.outputMode === "json" ? "json" : "readable");
      });
      copyJsonButton?.addEventListener("click", async () => {
        if (!latestJson) return;
        await navigator.clipboard?.writeText(latestJson);
        copyJsonButton.textContent = "Copied";
        window.setTimeout(() => {
          copyJsonButton.textContent = "Copy JSON";
        }, 1400);
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!resultPanel || !readableOutput || !output || !summary || !statusText || !submitButton) return;

        const slug = form.getAttribute("data-tool-slug");
        const formData = new FormData(form);
        const params = new URLSearchParams();

        for (const [key, value] of formData.entries()) {
          const text = String(value).trim();
          if (text) params.set(key, text);
        }

        statusText.textContent = "Lagi dicek...";
        submitButton.disabled = true;

        try {
          const response = await fetch(`/api/tools/${slug}?${params.toString()}`, {
            headers: { accept: "application/json" }
          });
          const payload = await response.json();

          if (!payload.ok) {
            throw new Error(payload.error || "Tool gagal dijalankan.");
          }

          latestJson = JSON.stringify(payload.data, null, 2);
          output.textContent = latestJson;
          readableOutput.innerHTML = renderReadableOutput(payload.data);
          summary.textContent = `${toolLabels[payload.data.tool] ?? "Tool"} untuk ${params.get("target") ?? "target"} selesai dalam ${payload.data.durationMs} ms.`;
          resultPanel.classList.remove("hidden");
          setOutputMode(resultPanel, "readable");
          statusText.textContent = `Selesai dalam ${payload.data.durationMs} ms.`;
        } catch (error) {
          latestJson = JSON.stringify(
            { error: error instanceof Error ? error.message : "Tool gagal dijalankan." },
            null,
            2
          );
          output.textContent = latestJson;
          readableOutput.innerHTML = shell("Tool gagal", "Cek detail error di bawah.", valueList([latestJson]), "warning");
          summary.textContent = "Request belum berhasil diproses.";
          resultPanel.classList.remove("hidden");
          setOutputMode(resultPanel, "readable");
          statusText.textContent = "Gagal. Cek output untuk detailnya.";
        } finally {
          submitButton.disabled = false;
        }
      });
    }

    initializeToolForm();
    document.addEventListener("astro:page-load", initializeToolForm);
  </script>
</BaseLayout>
