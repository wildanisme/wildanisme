---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectHero from "@components/project/ProjectHero.astro";
import ProjectMeta from "@components/project/ProjectMeta.astro";
import ProjectGallery from "@components/project/ProjectGallery.astro";
import ContentLayout from "@components/blog/ContentLayout.astro";
import { site } from "@data/site";
import { breadcrumbJsonLd } from "@lib/structured-data";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => data.isPublished);
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const clients = await getCollection("clients", ({ data }) => data.isPublished);
const { Content } = await render(project);
const projectUrl = new URL(`/projects/${project.data.slug}`, site.url).toString();
const projectImage = project.data.coverImage ?? project.data.gallery[0]?.image;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: project.data.title,
    description: project.data.summary,
    url: projectUrl,
    creator: {
      "@type": "Person",
      name: site.owner
    }
  },
  breadcrumbJsonLd([
    { name: "Beranda", url: site.url },
    { name: "Project", url: new URL("/projects", site.url).toString() },
    { name: project.data.title, url: projectUrl }
  ])
];
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  canonical={`/projects/${project.data.slug}`}
  image={projectImage}
  structuredData={structuredData}
>
  <ProjectHero project={project} clients={clients} />
  <section class="container grid min-w-0 items-start gap-10 lg:grid-cols-[320px_minmax(0,1fr)]">
    <ProjectMeta project={project} clients={clients} />
    <ContentLayout>
      <Content />
      <ProjectGallery gallery={project.data.gallery} projectSlug={project.data.slug} projectTitle={project.data.title} />
    </ContentLayout>
  </section>
</BaseLayout>
