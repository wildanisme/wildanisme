---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/shared/Button.astro";
import Section from "@components/shared/Section.astro";
import PageHeader from "@components/shared/PageHeader.astro";
import ProjectGrid from "@components/project/ProjectGrid.astro";
import { getPublishedClients, getPublishedProjects } from "@lib/content";

const projects = getPublishedProjects(await getCollection("projects"));
const clients = getPublishedClients(await getCollection("clients"));
---

<BaseLayout
  title="Portfolio Project"
  description="Daftar project wildanisme untuk web development, maintenance, bug fix, deploy aplikasi, hardening server, dan SEO teknis."
>
  <PageHeader
    eyebrow="Portfolio"
    title="Bukti kerja. Biar tidak cuma katanya-katanya."
    description="Setiap project ditulis sebagai konteks kerja: masalah awalnya apa, bagian mana yang saya pegang, stack yang dipakai, dan hasil yang bisa dilihat."
  >
    <div class="flex flex-wrap gap-3">
      <Button href="/projects" variant="primary">Semua project</Button>
      <Button href="/projects/personal" variant="secondary">Project personal</Button>
    </div>
  </PageHeader>
  <Section>
    <ProjectGrid projects={projects} clients={clients} />
  </Section>
</BaseLayout>
