---
import type { CollectionEntry } from "astro:content";
import Badge from "@components/shared/Badge.astro";
import Card from "@components/shared/Card.astro";
import FallbackImage from "@components/shared/FallbackImage.astro";
import { getClientLabel } from "@lib/content";

interface Props {
  project: CollectionEntry<"projects">;
  clients: CollectionEntry<"clients">[];
}

const { project, clients } = Astro.props;
const clientLabel = getClientLabel(clients, project.data.clientSlug);
const projectImage = project.data.coverImage ?? project.data.gallery[0]?.image;
---

<Card href={`/projects/${project.data.slug}`}>
  <FallbackImage
    src={projectImage}
    alt={`Cover project ${project.data.title}`}
    label={project.data.title}
    aspect="project"
  />
  <div class="grid gap-3.5 p-[18px]">
    <div class="flex items-center justify-between gap-3 text-[0.88rem] font-extrabold text-text-secondary">
      <Badge tone={project.data.clientSlug ? "accent" : "highlight"}>{clientLabel}</Badge>
      <span>{project.data.year}</span>
    </div>
    <h3 class="m-0 text-[1.22rem] leading-[1.25]">{project.data.title}</h3>
    <p class="m-0 leading-[1.6] text-text-secondary">{project.data.summary}</p>
    <div class="flex flex-wrap gap-1.5" aria-label="Teknologi">
      {
        project.data.stack.slice(0, 4).map((item) => (
          <span class="rounded-full border border-border bg-surface-muted px-2 py-1 text-[0.78rem] font-[750] text-text-secondary">
            {item}
          </span>
        ))
      }
    </div>
  </div>
</Card>
