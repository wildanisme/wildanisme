---
import type { CollectionEntry } from "astro:content";
import Badge from "@components/shared/Badge.astro";
import Button from "@components/shared/Button.astro";
import { getClient, getClientLabel } from "@lib/content";

interface Props {
  project: CollectionEntry<"projects">;
  clients: CollectionEntry<"clients">[];
}

const { project, clients } = Astro.props;
const client = getClient(clients, project.data.clientSlug);
---

<aside class="grid gap-4 rounded-card bg-surface p-5 shadow-brutal [border:var(--border-strong)]">
  <div>
    <span class="mb-1 block text-medium font-extrabold text-text-secondary">Role</span>
    {
      project.data.role.map((item) =>
        <ul><strong class="font-black underline">{item}</strong></ul>
    )}
  </div>
  <div>
    <span class="mb-1 block text-medium font-extrabold text-text-secondary">Tahun</span>
    <strong class="font-black">{project.data.year}</strong>
  </div>
  <div>
    <span class="mb-1 block text-medium font-extrabold text-text-secondary">Industri</span>
    {
      project.data.industry.map((item) =>
        <ul><strong class="font-black underline">{item}</strong></ul>
    )}
  </div>
  <div>
    <span class="mb-1 block text-medium font-extrabold text-text-secondary">Klien</span>
    {
      client?.data.isPublic ? (
        <a class="font-black underline decoration-2 underline-offset-4" href={`/clients/${client.data.slug}`}>{client.data.name}</a>
      ) : (
        <strong class="font-black">{getClientLabel(clients, project.data.clientSlug)}</strong>
      )
    }
  </div>
  <div>
    <span class="mb-1 block text-[0.82rem] font-extrabold text-text-secondary">Stack</span>
    <div class="flex flex-wrap gap-1.5">
      {project.data.stack.map((item) => <Badge tone="neutral">{item}</Badge>)}
    </div>
  </div>
  {
    project.data.links.length > 0 && (
      <div>
        <span class="mb-2 block text-[0.82rem] font-extrabold text-text-secondary">Tautan</span>
        <ul class="grid gap-2">
          {project.data.links.map((link) => (
            <li>
              <a
                class="inline-flex w-full items-center justify-between gap-3 rounded-card bg-surface-muted px-3 py-2.5 font-black underline decoration-2 underline-offset-4 transition-[transform,box-shadow,background] duration-150 ease-in-out [border:var(--border-strong)] hover:translate-x-px hover:translate-y-px hover:bg-accent-soft hover:[box-shadow:1px_1px_0_var(--color-text-primary)]"
                href={link.url}
                target="_blank"
                rel="noreferrer"
              >
                <span>{link.label}</span>
                <span aria-hidden="true">-&gt;</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
  {
    project.data.demoUrl && (
      <Button href={project.data.demoUrl} variant="primary">
        Lihat demo
      </Button>
    )
  }
</aside>
