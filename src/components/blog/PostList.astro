---
import type { CollectionEntry } from "astro:content";
import PostCard from "@components/blog/PostCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 ? (
    <div class="grid grid-cols-3 gap-[22px] max-lg:grid-cols-2 max-sm:grid-cols-1">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  ) : (
    <div class="rounded-card bg-surface p-7 shadow-brutal [border:var(--border-strong)]">
      <h3>Belum ada tulisan</h3>
      <p>Tulisan akan tampil setelah dipublikasikan.</p>
    </div>
  )
}
