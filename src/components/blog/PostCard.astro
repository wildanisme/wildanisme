---
import type { CollectionEntry } from "astro:content";
import Badge from "@components/shared/Badge.astro";
import Card from "@components/shared/Card.astro";
import FallbackImage from "@components/shared/FallbackImage.astro";
import { formatDate } from "@lib/content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<Card href={`/blog/${post.data.slug}`}>
  <FallbackImage
    src={post.data.coverImage}
    alt={`Cover tulisan ${post.data.title}`}
    label={post.data.category}
    aspect="wide"
  />
  <div class="grid gap-3.5 p-[18px]">
    <div class="flex items-center justify-between gap-3 text-[0.84rem] font-extrabold text-text-secondary">
      <Badge tone="accent">{post.data.category}</Badge>
      <span>{formatDate(post.data.publishedAt)}</span>
    </div>
    <h3 class="m-0 text-[1.18rem] leading-[1.3]">{post.data.title}</h3>
    <p class="m-0 leading-[1.6] text-text-secondary">{post.data.description}</p>
  </div>
</Card>
