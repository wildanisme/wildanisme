---
import Button from "@components/shared/Button.astro";
import Badge from "@components/shared/Badge.astro";
import { proofPoints, site } from "@data/site";
---

<section class="py-[72px] pb-14">
  <div class="mx-auto grid w-[calc(100%_-_32px)] max-w-[1120px] items-center gap-9 max-[720px]:w-[calc(100%_-_24px)] min-[921px]:grid-cols-[minmax(0,1fr)_minmax(320px,0.72fr)]">
    <div class="grid gap-[22px]">
      <Badge tone="accent">Web Dev / Sysadmin / SEO</Badge>
      <h1 class="m-0 max-w-[840px] text-[3rem] font-black leading-[0.96] min-[521px]:text-[3.6rem] min-[921px]:text-[4.8rem]">
        Website rewel? Server deg-degan? SEO cuma pajangan? Sini diberesin.
      </h1>
      <p class="m-0 max-w-[700px] text-[1.18rem] leading-[1.7] text-text-secondary">
        Saya {site.owner}, orang di balik {site.brand}. Saya bantu maintenance,
        bug fix, optimasi, deploy aplikasi, hardening server, dan SEO teknis.
        Santai aja, yang penting masalahnya ketahuan dan fix-nya jelas.
      </p>
      <div class="flex flex-wrap gap-3">
        <Button href="/contact">Ceritakan rewelnya</Button>
        <Button href="/projects" variant="secondary">Lihat kerjaan saya</Button>
      </div>
    </div>
    <div class="self-stretch overflow-hidden rounded-card bg-surface shadow-brutal [border:var(--border-strong)]" aria-label="Ringkasan profil">
      <div class="flex gap-2 border-b-[3px] border-text-primary bg-accent p-3.5">
        <span class="h-3 w-3 rounded-full border-2 border-text-primary bg-surface"></span>
        <span class="h-3 w-3 rounded-full border-2 border-text-primary bg-surface"></span>
        <span class="h-3 w-3 rounded-full border-2 border-text-primary bg-surface"></span>
      </div>
      <div class="grid gap-3.5 p-6">
        <p class="m-0 font-mono text-[0.92rem] text-text-secondary">$ whoami</p>
        <strong class="text-[1.12rem]">{site.owner}</strong>
        <p class="m-0 font-mono text-[0.92rem] text-text-secondary">$ role</p>
        <strong class="text-[1.12rem]">Web Development, Sysadmin/DevOps, SEO</strong>
        <p class="m-0 font-mono text-[0.92rem] text-text-secondary">$ I fix</p>
        <strong class="text-[1.12rem]">Bug nyebelin, deploy deg-degan, SEO sepi</strong>
        <div class="mt-3 grid gap-3">
          {proofPoints.map((item) => (
            <div class="rounded-card border-2 border-text-primary bg-surface-muted p-3">
              <span class="mb-1 block text-[0.82rem] font-extrabold text-text-secondary">{item.label}</span>
              <strong>{item.value}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
